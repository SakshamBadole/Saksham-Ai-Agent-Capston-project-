# App configuration
PORT=8000
ENVIRONMENT=development

# Database configuration
# For Docker setup, use 'db' instead of 'localhost' if running within the same docker network.
# For running locally on host connecting to Docker:
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/smartseller

# Security configurations
JWT_SECRET_KEY=9a60e0a5c4d0a158b0f803c734e565bf5160893a74ef4ee5a6669f10a80e15c2
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Models configuration (Gemini API)
